# Repo-root .env — for one-off scripts (scripts/*.mjs).
# Copy to .env and fill in the real values. .env itself is gitignored.

# Supabase project — same project for staging + prod (no separate envs yet).
# URL is public, key is NOT — keep service_role out of git, frontend, chat logs.
# Find under: Supabase dashboard → Project Settings → API → service_role
SUPABASE_URL=https://yqeegfhwbjnlrdurstxp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional — only needed if a script sends email via Resend.
# Find under: resend.com → API Keys
RESEND_API_KEY=

# Optional — only needed for scripts/enrich-with-google-places.mjs.
# Get one at console.cloud.google.com → APIs & Services → Credentials.
# Required APIs: "Places API (New)". $200/month free credit covers
# typical enrichment runs.
GOOGLE_MAPS_API_KEY=
